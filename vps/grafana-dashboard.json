      "type": "gauge",
      "title": "SOC Batterie",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._field == \"battery_soc\")\n  |> last()",
          "refId": "A"
        }
      ],
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }
    },
